PORT=4000
NODE_ENV=development

# JWT secrets - CHANGE THESE IN PRODUCTION
JWT_ACCESS_SECRET=eduflow_access_secret_change_me_in_production
JWT_REFRESH_SECRET=eduflow_refresh_secret_change_me_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - frontend origin
CLIENT_ORIGIN=http://localhost:5173

# Business rules (defaults, also editable from Settings page)
DEFAULT_MONTHLY_LESSONS=12
DEFAULT_MONTHLY_FEE=250000
SIBLING_DISCOUNT_PERCENT=10
MULTI_COURSE_DISCOUNT_PERCENT=10
